.text
    # WAW (Write-After-Write)
    addi x1, x0, 5
    addi x1, x0, 10         # Overwrites x1 cleanly
    
    # RAW (Read-After-Write)
    add  x2, x1, x1         # x2 = 10 + 10 = 20
    addi x3, x2, 5          # x3 = 20 + 5 = 25
    
    # RAR (Read-After-Read)
    add  x4, x1, x2         # x4 = 10 + 20 = 30
    add  x5, x1, x2         # x5 = 10 + 20 = 30
    
    addi x17, x0, 10        # RARS Halt Code
    ecall